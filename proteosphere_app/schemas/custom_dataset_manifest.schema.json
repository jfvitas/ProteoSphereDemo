{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proteosphere.local/schemas/custom_dataset_manifest.schema.json",
  "title": "ProteoSphere Custom Dataset Manifest",
  "type": "object",
  "required": ["manifest_id", "entity_kind", "records"],
  "properties": {
    "manifest_id": {"type": "string", "minLength": 1},
    "title": {"type": "string"},
    "task_type": {"type": "string"},
    "label_type": {"type": "string"},
    "entity_kind": {
      "type": "string",
      "enum": ["protein_pair", "protein_ligand", "structure_pair"]
    },
    "split_membership_mode": {"type": "string"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["record_id"],
        "properties": {
          "record_id": {"type": "string", "minLength": 1},
          "split": {"type": "string", "enum": ["", "train", "val", "test"]},
          "protein_a": {"type": "string"},
          "protein_b": {"type": "string"},
          "protein_accessions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "ligand_id": {"type": "string"},
          "ligand_smiles": {"type": "string"},
          "ligand_chemical_series": {"type": "string"},
          "pdb_id": {"type": "string"},
          "motif_domain_signatures": {
            "type": "array",
            "items": {"type": "string"}
          },
          "source_dataset": {"type": "string"},
          "source_family": {"type": "string"},
          "assay_family": {"type": "string"},
          "measurement_type": {"type": "string"},
          "label_value": {},
          "provenance_note": {"type": "string"},
          "extra_metadata": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
